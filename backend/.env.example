# ═══════════════════════════════════════════════
# AI 视频知识平台 — 环境变量配置
# 复制为 .env 并修改对应值
# ═══════════════════════════════════════════════

# ── 功能开关（默认全部开启，设为 false 禁用）──
FEATURE_AI=true
FEATURE_WHISPER=true

# ── AI 配置 ──
# AI 服务商：deepseek | openai | openrouter
AI_PROVIDER=deepseek
# API Key（必填才能使用 AI 功能）
AI_API_KEY=
# API Base URL
AI_BASE_URL=https://api.deepseek.com/anthropic
# 模型名称
AI_MODEL=deepseek-v4-flash

# ── Prompt 版本 ──
PROMPT_VERSION=1
SUMMARY_PROMPT_VERSION=2
NOTES_PROMPT_VERSION=1
MINDMAP_PROMPT_VERSION=1
QANDA_PROMPT_VERSION=1

# ── Whisper 配置 ──
# 模型大小：tiny | base | small | medium | large
WHISPER_MODEL=small
# 字幕校正开关
SUBTITLE_CORRECTION_ENABLED=true
SUBTITLE_CORRECTION_MAX_CHARS=15000
# 转录最大视频时长（秒），0 表示不限制
WHISPER_MAX_DURATION=0
# HuggingFace 镜像（国内加速）
HF_ENDPOINT=https://hf-mirror.com

# ── 运行时路径 ──
# 本地开发不配置时，默认写入 backend/ 下的对应目录。
# 生产安装脚本会自动追加以下绝对路径；DATA_DIR 只供部署脚本使用。
# DATA_DIR=/var/lib/videomind
# DB_PATH=/var/lib/videomind/db/knowledge.db
# AI_CONFIG_PATH=/var/lib/videomind/ai_config.json
# TEMP_DIR=/var/lib/videomind/temp
# DOWNLOAD_DIR=/var/lib/videomind/downloads
# WHISPER_MODELS_DIR=/var/lib/videomind/whisper_models
# BACKUP_DIR=/var/lib/videomind/backups

# ── 运维保留策略 ──
BACKUP_RETENTION_DAYS=14
TEMP_RETENTION_DAYS=2
DOWNLOAD_RETENTION_DAYS=14

# ── 用户体系 ──
# 管理员账号（ADMIN_PASSWORD 为空则不会自动创建 admin）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# 注册开关
REGISTRATION_ENABLED=true
# 游客密钥（生产环境必须修改）
GUEST_SECRET=请替换为随机长字符串
# 每日限额
GUEST_DAILY_LIMIT=3
USER_DAILY_LIMIT=20

# ── CORS ──
# 逗号分隔的域名白名单，* 表示允许所有
CORS_ORIGINS=*

# ── 服务端口 ──
# 后端端口（默认 8000）
# 前端端口（默认 5173，由 vite.config.js 控制）
